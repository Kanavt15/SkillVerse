# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=skillverse
DB_PORT=3306
# DB_SSL=true                    # Enable for production

# JWT Configuration
# IMPORTANT: Generate a strong, unique secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Refresh Token Configuration
# Access tokens are fixed at 15 minutes, refresh tokens default to 7 days
REFRESH_TOKEN_EXPIRY_DAYS=7

# Redis Configuration (for caching and distributed rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=skillverse:

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# CORS Configuration
CLIENT_URL=http://localhost:3000
